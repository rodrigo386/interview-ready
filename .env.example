# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Gemini — required for all AI calls (sections, ATS, company intel,
# CV rewrite, JD cleanup). Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Asaas (Brazilian payment gateway). Sandbox values for local dev.
# Sandbox: https://sandbox.asaas.com/api/v3   Prod: https://api.asaas.com/v3
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Arbitrary 32+ chars; must match the `asaas-access-token` header configured
# in the Asaas webhook panel.
ASAAS_WEBHOOK_TOKEN=

# Upstash Redis — optional. Enables rate limiting in prod. When unset,
# the rate-limit helper fails open (no blocking).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Test bypass — DO NOT set in production. Used only by E2E auth tests
# against a staging Supabase to confirm @example.com test emails without
# a real inbox. See tests/e2e/auth-required/_helpers.ts.
E2E_BYPASS_SECRET=

# Test-only kill switch for AI calls (legacy name from when we used
# Anthropic — value still '1' enables Gemini mocks).
MOCK_ANTHROPIC=
